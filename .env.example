# Lightcrawl Environment Variables Example

# The port Express HTTP server listens on (default is 3000)
PORT=3000

# Execution mode (development, production, test)
NODE_ENV=development

# API Key for HTTP API authentication (Optional. If set, clients must authenticate)
# API_KEY=your-secure-api-key-here

# Allowed IP addresses for HTTP API access (Optional. Comma-separated list. If set, other IPs are blocked)
# ALLOWED_IPS=127.0.0.1,203.0.113.50
